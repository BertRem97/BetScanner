# OddsPapi API Configuration
# Single key:
ODDSPAPI_KEY=your_oddspapi_api_key_here
# OR multiple keys (comma-separated) for load balancing:
# ODDSPAPI_KEYS=key1,key2,key3

# Requests per key per month (default: 250 for free tier)
REQUESTS_PER_KEY=250

# Telegram Configuration (for notifications and commands)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Google Sheets Configuration (for logging and profit tracking)
GOOGLE_CREDENTIALS_PATH=path/to/service-account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# Stake Calculation
KELLY_FRACTION=0.25
BANKROLL=1000

# Scanner Settings
MIN_EV_THRESHOLD=2.0
SPORT_ID=10
MAX_TOURNAMENTS=10
DAYS_AHEAD=7
REQUEST_DELAY=1.0
SCAN_INTERVAL=300

# VPN Configuration (Surfshark on Raspberry Pi)
# Set VPN_ENABLED=true to activate rotation
# VPN_SERVERS: comma-separated Surfshark server IDs (see: surfshark-vpn server list)
# VPN_ROTATE_EVERY: rotate after this many API requests
VPN_ENABLED=false
VPN_SERVERS=nl-ams,de-fra,gb-lon,fr-par,be-bru
VPN_ROTATE_EVERY=10
